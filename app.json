{
  "expo": {
    "name": "HealthChat",
    "slug": "healthchat-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3DBCA2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.healthchat.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "HealthChat needs camera access for video consultations.",
        "NSMicrophoneUsageDescription": "HealthChat needs microphone access for video consultations.",
        "NSPhotoLibraryUsageDescription": "HealthChat needs photo library access to upload patient vitals images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3DBCA2"
      },
      "package": "com.healthchat.mobile",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "HealthChat needs camera access for video consultations."
        }
      ]
    ]
  }
}
